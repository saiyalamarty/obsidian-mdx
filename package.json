{
	"name": "obsidian-mdx",
	"version": "0.1.0",
	"private": true,
	"description": "Render trusted MDX and React components inside native Obsidian notes.",
	"main": "main.js",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/saiyalamarty/obsidian-mdx.git"
	},
	"bugs": {
		"url": "https://github.com/saiyalamarty/obsidian-mdx/issues"
	},
	"homepage": "https://github.com/saiyalamarty/obsidian-mdx#readme",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"dev": "npm run build:css && node esbuild.config.mjs",
		"build": "npm run build:css && tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"build:css": "mkdir -p .build && tailwindcss -i src/styles/tailwind.css -o .build/mdx-components.css --minify && node scripts/embed-component-styles.mjs",
		"test": "npm run build:css && vitest run",
		"test:watch": "vitest",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"mdx",
		"react",
		"shadcn"
	],
	"author": "Sai Yalamarty",
	"license": "0-BSD",
	"devDependencies": {
		"@codemirror/state": "^6.5.0",
		"@codemirror/view": "^6.38.6",
		"@eslint/js": "^9.39.4",
		"@tailwindcss/cli": "^4.3.3",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^22.15.17",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"jsdom": "^26.1.0",
		"obsidian": "latest",
		"shadcn": "^4.13.1",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@mdx-js/mdx": "^3.1.1",
		"@shadcn/react": "^0.2.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"date-fns": "^4.4.0",
		"embla-carousel-react": "^8.6.0",
		"input-otp": "^1.4.2",
		"lucide-react": "^1.25.0",
		"next-themes": "^0.4.6",
		"react": "^19.2.7",
		"react-day-picker": "^10.0.1",
		"react-dom": "^19.2.7",
		"react-resizable-panels": "^4.12.2",
		"recharts": "^3.8.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0"
	}
}
